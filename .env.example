# Consolida — variáveis de ambiente (12-factor). Copie para .env e ajuste.
# NUNCA commite o .env real.

APP_ENV=development

# Postgres (usado pelo container db)
POSTGRES_USER=consolida
POSTGRES_PASSWORD=change-me
POSTGRES_DB=consolida
# Porta publicada no host (mude se 5432 já estiver em uso localmente)
DB_PORT=5432

# Conexão da API com o banco.
#  - via docker compose: host = db
#  - dev local fora do Docker: host = localhost
DATABASE_URL=postgresql+psycopg://consolida:change-me@db:5432/consolida
