# Consolida — variáveis de ambiente (12-factor). Copie para .env e ajuste.
# NUNCA commite o .env real.

APP_ENV=development

# Deploy (docker-compose.prod.yml via ./deploy.sh)
# DOMAIN: se preenchido, o Caddy emite HTTPS automático nesse domínio
# (aponte o DNS para o servidor e abra as portas 80/443). Vazio = HTTP na :80.
DOMAIN=
# SITE_ADDRESS é derivado do DOMAIN pelo deploy.sh — não precisa mexer.
SITE_ADDRESS=:80

# Postgres (usado pelo container db)
POSTGRES_USER=consolida
POSTGRES_PASSWORD=change-me
POSTGRES_DB=consolida
# Porta publicada no host (mude se 5432 já estiver em uso localmente)
DB_PORT=5432

# Conexão da API com o banco.
#  - via docker compose: host = db
#  - dev local fora do Docker: host = localhost
DATABASE_URL=postgresql+psycopg://consolida:change-me@db:5432/consolida
# Pool de conexões (ajuste conforme concorrência esperada)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800

# Auth / JWT (F2) — gere um segredo forte: openssl rand -hex 32
JWT_SECRET=troque-por-um-segredo-aleatorio-forte
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_MINUTES=43200

# Cofre de credenciais (F4 / ADR-005) — gere com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAULT_KEY=troque-por-uma-chave-fernet-valida

# Agregador Pluggy (F4) — credenciais de sandbox/produção (opcionais)
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
PLUGGY_BASE_URL=https://api.pluggy.ai

# Webhook do Pluggy (F9)
# URL pública HTTPS do receptor — enviada no connect_token (options.webhookUrl).
# Sem ela, os itens criados NÃO notificam.
PLUGGY_WEBHOOK_URL=
# Autenticação do webhook (o Pluggy NÃO assina o payload / sem HMAC):
#  - header secreto: configure o mesmo header+valor ao criar o Webhook na Pluggy
#  - e/ou allowlist de IP de origem (csv). Em produção, exija ao menos um.
PLUGGY_WEBHOOK_SECRET=
PLUGGY_WEBHOOK_HEADER=x-webhook-secret
PLUGGY_WEBHOOK_ALLOWED_IPS=

# CORS — origens permitidas (csv). Em produção NÃO pode ser "*" (falha no boot).
CORS_ORIGINS=*

# Rate limiting de endpoints caros (sync/dashboard) por usuário
API_RATE_LIMIT_MAX=60
API_RATE_LIMIT_WINDOW_SECONDS=60
# Só ative atrás de proxy/LB confiável (senão o IP pode ser forjado no rate limit)
TRUST_FORWARDED_FOR=false
