# Server block para o nginx do HOST (VPS).
# O deploy.sh gera uma versão preenchida (nginx-host.conf) com o seu DOMAIN.
#
# Instalação:
#   sudo cp nginx-host.conf /etc/nginx/sites-available/consolida
#   sudo ln -s /etc/nginx/sites-available/consolida /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d SEU_DOMINIO      # emite o TLS e ajusta este bloco
#
# Troque SEU_DOMINIO e, se mudou a porta, WEB_PORT (padrão 8080).

server {
    listen 80;
    listen [::]:80;
    server_name SEU_DOMINIO;

    # Encaminha tudo para o container `web` (nginx do SPA + proxy /api),
    # publicado em 127.0.0.1:WEB_PORT pelo docker-compose.prod.yml.
    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    client_max_body_size 10m;
}

# Depois de rodar `certbot --nginx -d SEU_DOMINIO`, ele adiciona automaticamente
# o bloco `listen 443 ssl` com os certificados e o redirect 80 → 443.
