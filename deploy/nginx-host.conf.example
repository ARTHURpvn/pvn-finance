# Template do server block para o nginx do HOST (VPS).
# O deploy.sh gera uma versão preenchida em deploy/sites/<seu-dominio> —
# o arquivo tem o NOME DO DOMÍNIO (padrão p/ gerenciar vários domínios).
#
# Instalação (troque SEU_DOMINIO pelo seu domínio; o deploy.sh imprime pronto):
#   sudo cp deploy/sites/SEU_DOMINIO /etc/nginx/sites-available/SEU_DOMINIO
#   sudo ln -s /etc/nginx/sites-available/SEU_DOMINIO /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d SEU_DOMINIO      # emite o TLS e ajusta este bloco

server {
    listen 80;
    listen [::]:80;
    server_name SEU_DOMINIO;

    # Encaminha tudo para o container `web` (nginx do SPA + proxy /api),
    # publicado em 127.0.0.1:WEB_PORT pelo docker-compose.prod.yml.
    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    client_max_body_size 10m;
}

# Depois de rodar `certbot --nginx -d SEU_DOMINIO`, ele adiciona automaticamente
# o bloco `listen 443 ssl` com os certificados e o redirect 80 → 443.
