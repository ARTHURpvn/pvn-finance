# SITE_ADDRESS = domínio (ex.: consolida.seudominio.com) → HTTPS automático.
# Se vazio, cai em :80 (HTTP simples, útil para testar por IP).
{$SITE_ADDRESS::80} {
	encode gzip zstd

	# API: /api/* → api:8000 (o prefixo /api é removido antes de repassar).
	handle_path /api/* {
		reverse_proxy api:8000
	}

	# SPA: serve os arquivos estáticos; rotas do React Router caem no index.html.
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
